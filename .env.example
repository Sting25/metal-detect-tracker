# =============================================================================
# Metal Detect Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# REQUIRED variables must be set for the app to start.
# OPTIONAL variables enable additional features — the app works without them.
# =============================================================================

# --- REQUIRED ----------------------------------------------------------------

# PostgreSQL connection string
# Create the database first:  createdb metal_detect_tracker
DATABASE_URL=postgresql://localhost:5432/metal_detect_tracker

# JWT secret for signing auth tokens (REQUIRED — app won't start without it)
# Generate one:  openssl rand -hex 32
JWT_SECRET=

# --- OPTIONAL: Server --------------------------------------------------------

# Port to listen on (default: 3000)
# PORT=3000

# Set to "production" for production deployments
# NODE_ENV=development

# --- OPTIONAL: File Storage (S3-compatible) ----------------------------------
# Required for photo uploads. Without this, upload features won't work.
# Works with DigitalOcean Spaces, AWS S3, MinIO, or any S3-compatible service.

# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_BUCKET=your-bucket-name
# DO_SPACES_KEY=your-access-key
# DO_SPACES_SECRET=your-secret-key
# DO_SPACES_REGION=nyc3

# --- OPTIONAL: Email (SendGrid) ---------------------------------------------
# Enables email verification, password reset emails, and admin notifications.
# Without this, those features degrade gracefully (no emails sent).

# SENDGRID_API_KEY=SG.your-api-key
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=Metal Detect Tracker

# Set to "true" to require email verification on registration (default: false)
# EMAIL_VERIFICATION_ENABLED=false

# --- OPTIONAL: SMS (Twilio Verify) -------------------------------------------
# Enables phone-based password reset. Without this, SMS features are disabled.

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPTIONAL: Google OAuth --------------------------------------------------
# Enables "Sign in with Google" on the login page.
# Create credentials at https://console.cloud.google.com/apis/credentials

# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- OPTIONAL: WebAuthn Passkeys ---------------------------------------------
# Enables passwordless login with passkeys/biometrics.
# RP_ID must match the domain users access the app from.

# WEBAUTHN_RP_NAME=Metal Detect Tracker
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:3000

# --- OPTIONAL: Base URL ------------------------------------------------------
# Used for generating links in permission letters and emails.
# Default: http://localhost:3000

# BASE_URL=https://yourdomain.com

# --- OPTIONAL: Admin Bootstrap -----------------------------------------------
# Controls whether the /setup endpoint is available for creating the first admin.
# Default: enabled. Set to "false" after your initial admin account is created.

# ALLOW_SETUP=true
